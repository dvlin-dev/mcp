{
  "name": "@moryflow/macos-kit",
  "version": "0.1.0",
  "description": "MCP Server for macOS automation with AppleScript/JXA",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "macos-kit-mcp": "dist/transports/stdio.js"
  },
  "files": [
    "dist/**/*",
    "knowledge-base/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev:stdio": "tsx src/transports/stdio.ts",
    "test": "tsx --test tests/*.test.ts",
    "test:coverage": "c8 --reporter=text-summary --reporter=text tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "dotenv": "^16.4.0",
    "fuse.js": "^7.1.0",
    "gray-matter": "^4.0.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "c8": "^10.1.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
